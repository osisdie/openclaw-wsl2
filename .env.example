TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/{your-hook-id}"
OPENROUTER_API_KEY="sk-***"

# Gemini API key (from https://aistudio.google.com/apikey)
# Used by test scripts only. openclaw itself uses OAuth via google-gemini-cli-auth plugin.
GEMINI_API_KEY="AI***"


# Discord Application Bot Key (from https://discord.com/developers/applications)
DISCORD_BOT_TOKEN="MTIz***"

# Gemini CLI OAuth credentials (from @google/gemini-cli-core)
# Used by openclaw google-gemini-cli-auth plugin to bypass pnpm shim path resolution
# Extract from: node_modules/@google/gemini-cli-core/dist/src/code_assist/oauth2.js
# Needed when pnpm shim prevents openclaw from auto-discovering credentials
GEMINI_CLI_OAUTH_CLIENT_ID="your-oauth-client-id.apps.googleusercontent.com"
GEMINI_CLI_OAUTH_CLIENT_SECRET="your-secret"
